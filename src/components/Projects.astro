---
import { Image } from "astro:assets";
import coment01 from "../assets/img/coment01.avif";
import coment02 from "../assets/img/coment02.avif";
import avatarMano from "../assets/img/avatar-mano.jpg";
import avatarIvan from "../assets/img/avatar-ivan.jpg";
---

<section
    id="proyectos"
    class="py-24 lg:px-16 bg-[#FAFAFA] px-6"
    data-purpose="stacked-cards-section"
>
    <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16 scroll-reveal">
            <span
                class="inline-block bg-gray-800 text-white text-xs font-semibold px-3 py-1 rounded-full mb-4"
                >Nuestros Proyectos</span
            >
            <h2
                class="font-semibold tracking-tight text-gray-900 mb-4 text-4xl"
            >
                Visualizá tu Futuro Espacio.
            </h2>
            <p class="text-gray-600 text-xl">
                Así transformamos metros cuadrados sin uso en experiencias de
                vida únicas.
            </p>
        </div>

        <!-- Cards Container with gap to allow scrolling -->
        <div class="relative flex flex-col gap-[40vh] pb-[10vh]">
            <!-- Card 1: Project -->
            <div
                class="stacked-card sticky top-20 bg-[#EEF0F3] rounded-2xl overflow-hidden flex flex-col md:flex-row transform-gpu origin-top shadow-xl"
            >
                <div class="w-full md:w-2/5">
                    <Image
                        alt="Rooftop y Relax"
                        class="w-full h-full object-cover"
                        src={coment01}
                        loading="lazy"
                        format="avif"
                        widths={[400, 800]}
                        sizes="(max-width: 768px) 100vw, 40vw"
                    />
                </div>
                <div
                    class="w-full md:w-3/5 px-8 py-4 lg:p-16 flex flex-col justify-center bg-[#EEF0F3]"
                >
                    <h3 class="text-3xl font-semibold text-gray-900 mb-4">
                        Rooftop y Relax.
                    </h3>
                    <p class="text-gray-600 mb-8 leading-relaxed text-sm">
                        Este concepto de transformación integral combina un área
                        de cocina semicubierta con parrilla y comedor, junto a
                        un estetico solárium con deck WPC y piscina. El diseño
                        maximiza el espacio y crea zonas diferenciadas para el
                        relax y la vida social.
                    </p>
                    <div class="border-t border-gray-300 pt-8 mt-auto">
                        <p class="text-gray-600 text-sm italic mb-6 relative">
                            <span
                                class="absolute -left-4 -top-2 text-2xl text-gray-400 font-serif"
                                >"</span
                            >
                            Un proyecto llave en mano que no solo multiplica los metros
                            cuadrados disfrutables de tu hogar, sino que incrementa
                            de forma directa y significativa el valor de reventa o
                            alquiler de la propiedad.
                        </p>
                        <div class="flex items-center gap-3">
                            <Image
                                alt="Usuario"
                                class="w-10 h-10 rounded-full object-cover"
                                src={avatarMano}
                                width={48}
                                height={48}
                                format="avif"
                            />
                            <span class="text-xs font-medium text-gray-900"
                                >Mano De Melo</span
                            >
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card 2: Guarantee -->
            <div
                class="stacked-card sticky top-32 bg-[#111215] rounded-2xl overflow-hidden flex flex-col md:flex-row text-white transform-gpu origin-top shadow-2xl"
            >
                <div class="w-full md:w-2/5">
                    <Image
                        alt="Terraza de noche"
                        class="w-full h-full object-cover"
                        src={coment02}
                        loading="lazy"
                        format="avif"
                        widths={[400, 800]}
                        sizes="(max-width: 768px) 100vw, 40vw"
                    />
                </div>
                <div
                    class="w-full md:w-3/5 p-12 lg:p-16 flex flex-col justify-center bg-[#111215]"
                >
                    <h3 class="text-3xl font-semibold mb-6">
                        Confianza y Profesionalismo:<br />Nuestra Garantía.
                    </h3>
                    <p class="text-gray-400 mb-10 leading-relaxed text-sm">
                        Para nosotros, cada proyecto es un compromiso de
                        confianza. Nos enorgullece cumplir rigurosamente con los
                        plazos pactados y ofrecer una ejecución profesional de
                        principio a fin, asegurando no solo un resultado
                        estético superior, sino también la tranquilidad de
                        nuestros clientes.
                    </p>
                    <div class="border-t border-gray-800 pt-8 mt-auto">
                        <p class="text-gray-300 text-sm italic mb-6 relative">
                            <span
                                class="absolute -left-4 -top-2 text-3xl text-gray-700 font-serif"
                                >"</span
                            >
                            "Estoy feliz de haber trabajado con el equipo de Mano
                            Melo. No solo cumplieron con los plazos del contrato,
                            sino que su profesionalismo es destacable. Disfrutamos
                            del nuevo espacio junto a familia y amigos que están tan
                            encantados como nosotros."
                        </p>
                        <div class="flex items-center gap-3">
                            <Image
                                alt="Ivan"
                                class="w-10 h-10 rounded-full object-cover border border-gray-600"
                                src={avatarIvan}
                                width={48}
                                height={48}
                                format="avif"
                            />
                            <span class="text-xs font-medium text-gray-300"
                                >Ivan</span
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const stackedCards = document.querySelectorAll(".stacked-card");

            window.addEventListener("scroll", () => {
                window.requestAnimationFrame(() => {
                    stackedCards.forEach((card, index) => {
                        // The last card doesn't scale down
                        if (index === stackedCards.length - 1) {
                            card.style.transform = "scale(1)";
                            card.style.opacity = 1;
                            return;
                        }

                        const nextCard = stackedCards[index + 1];
                        const cardRect = card.getBoundingClientRect();
                        const nextRect = nextCard.getBoundingClientRect();

                        // Calculate distance between the tops of the current and next card
                        const distance = nextRect.top - cardRect.top;

                        // Only apply effect if the card has reached its sticky position (around 128px from top, we use a small buffer)
                        if (cardRect.top <= 140) {
                            // If next card is overlapping or about to overlap
                            if (distance > 0 && distance < cardRect.height) {
                                const progress = 1 - distance / cardRect.height;
                                // Scale from 1 down to 0.92
                                const scale = 1 - progress * 0.08;
                                card.style.transform = `scale(${scale})`;
                                // Fade slightly
                                card.style.opacity = 1 - progress * 0.4;
                            } else if (distance <= 0) {
                                // Completely covered
                                card.style.transform = "scale(0.92)";
                                card.style.opacity = 0.6;
                            } else {
                                // Next card is far away
                                card.style.transform = "scale(1)";
                                card.style.opacity = 1;
                            }
                        } else {
                            card.style.transform = "scale(1)";
                            card.style.opacity = 1;
                        }
                    });
                });
            });
        });
    </script>
</section>
<!-- END: StackedCardsSection -->
