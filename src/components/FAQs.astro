            <script>
                document.addEventListener("DOMContentLoaded", () => {
                    const faqItems = document.querySelectorAll(".faq-item");

                    faqItems.forEach((item) => {
                        const header = item.querySelector(".faq-header");
                        header.addEventListener("click", () => {
                            faqItems.forEach((otherItem) => {
                                if (
                                    otherItem !== item &&
                                    otherItem.classList.contains("is-active")
                                ) {
                                    otherItem.classList.remove("is-active");
                                    const otherContent =
                                        otherItem.querySelector(".faq-content");
                                    const otherTitle =
                                        otherItem.querySelector(".faq-title");
                                    const otherPlus =
                                        otherItem.querySelector(
                                            ".faq-icon-plus",
                                        );
                                    const otherClose =
                                        otherItem.querySelector(
                                            ".faq-icon-close",
                                        );

                                    otherContent.classList.remove(
                                        "grid-rows-[1fr]",
                                    );
                                    otherContent.classList.add(
                                        "grid-rows-[0fr]",
                                    );
                                    otherTitle.classList.remove(
                                        "font-semibold",
                                    );
                                    otherTitle.classList.add("font-medium");
                                    otherPlus.classList.remove("hidden");
                                    otherPlus.classList.add("block");
                                    otherClose.classList.remove("block");
                                    otherClose.classList.add("hidden");
                                }
                            });

                            item.classList.toggle("is-active");
                            const content = item.querySelector(".faq-content");
                            const title = item.querySelector(".faq-title");
                            const plus = item.querySelector(".faq-icon-plus");
                            const close = item.querySelector(".faq-icon-close");

                            if (item.classList.contains("is-active")) {
                                content.classList.remove("grid-rows-[0fr]");
                                content.classList.add("grid-rows-[1fr]");
                                title.classList.remove("font-medium");
                                title.classList.add("font-semibold");
                                plus.classList.remove("block");
                                plus.classList.add("hidden");
                                close.classList.remove("hidden");
                                close.classList.add("block");
                            } else {
                                content.classList.remove("grid-rows-[1fr]");
                                content.classList.add("grid-rows-[0fr]");
                                title.classList.remove("font-semibold");
                                title.classList.add("font-medium");
                                plus.classList.remove("hidden");
                                plus.classList.add("block");
                                close.classList.remove("block");
                                close.classList.add("hidden");
                            }
                        });
