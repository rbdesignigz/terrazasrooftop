---
import { Image } from 'astro:assets';
import proyCocina from '../assets/img/proy-cocina.avif';
import proyDecks from '../assets/img/proy-decks.avif';
import proyHidroia from '../assets/img/proy-hidroia.avif';
import proyPergola from '../assets/img/proy-pergola.avif';
import proyPanel from '../assets/img/proy-panel.avif';
import proyTecno from '../assets/img/proy-tecno.avif';
---
<section id="servicios" class="pt-12 px-8 lg:px-16 bg-[#FAFAFA]" data-purpose="services-section">
            <div class="max-w-6xl mx-auto">
                <div class="text-center mb-16">
                    <span
                        class="inline-block bg-gray-800 text-white text-xs font-semibold px-3 py-1 rounded-full mb-4">Servicios</span>
                    <h2 class="font-semibold tracking-tight text-gray-900 mb-4 text-5xl">Un Proyecto a Tu Medida</h2>
                    <p class="text-gray-600 text-2xl">Descubrí todo lo que podemos hacer para transformar tu
                        terraza.
                    </p>
                </div>
                <div class="flex flex-col lg:flex-row gap-16 items-start">
                    <!-- Left Service Image -->
                    <div class="w-full lg:w-1/2">
                        <Image alt="Servicio de Cocina en Terraza" id="service-image"
                            class="w-full rounded-lg shadow-md object-cover aspect-square transition-opacity duration-300 ease-in-out opacity-100"
                            src={proyCocina} loading="lazy" format="avif" widths={[400, 800]} sizes="(max-width: 768px) 100vw, 50vw" />
                    </div>
                    <!-- Right Accordion List (Visual representation of state) -->
                    <div class="w-full lg:w-1/2 flex flex-col gap-2">
                        <!-- Active Accordion Item -->
                        <div class="border-b border-gray-200 accordion-item is-active"
                            data-image={proyCocina.src}>
                            <div class="flex justify-between items-center py-4 cursor-pointer accordion-header">
                                <div class="flex items-center gap-4">
                                    <!-- Kitchen Icon -->
                                    <svg class="text-gray-700" fill="none" height="24" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                        viewbox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M12 2v20"></path>
                                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                                    </svg>
                                    <h3 class="text-lg font-semibold text-gray-900 accordion-title">Cocina</h3>
                                </div>
                                <button aria-label="Alternar detalle del servicio" class="text-gray-400 hover:text-gray-700">
                                    <svg class="icon-plus hidden" fill="none" height="20" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        viewbox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M5 12h14"></path>
                                        <path d="M12 5v14"></path>
                                    </svg>
                                    <svg class="icon-close block" fill="none" height="20" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        viewbox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M18 6 6 18"></path>
                                        <path d="m6 6 12 12"></path>
                                    </svg>
                                </button>
                            </div>
                            <div
                                class="accordion-content grid transition-[grid-template-rows] duration-300 ease-in-out grid-rows-[1fr]">
                                <div class="overflow-hidden">
                                    <p class="text-gray-600 pl-10 pr-4 text-sm leading-relaxed pb-6">
                                        Creamos un espacio cerrado o semicubierto totalmente equipado para ser el
                                        corazón de
                                        tu
                                        terraza. Diseñamos espacios funcionales y modernos que pueden incluir parrilla a
                                        gas
                                        o
                                        carbón, y todo el confort para disfrutar en cualquier época del año.
                                    </p>
                                </div>
                            </div>
                        </div>
                        <!-- Inactive Accordion Items -->
                        <div class="border-b border-gray-200 accordion-item" data-image={proyDecks.src}>
                            <div class="flex justify-between items-center py-5 cursor-pointer accordion-header">
                                <div class="flex items-center gap-4">
                                    <svg class="text-gray-700" fill="none" height="24" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                        viewbox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg">
                                        <rect height="18" rx="2" width="18" x="3" y="3"></rect>
                                        <path d="M3 9h18"></path>
                                        <path d="M9 21V9"></path>
                                    </svg>
                                    <h3 class="text-lg font-medium text-gray-900 accordion-title">Decks y Soláriums</h3>
                                </div>
                                <button aria-label="Alternar detalle del servicio" class="text-gray-400 hover:text-gray-700">
                                    <svg class="icon-plus block" fill="none" height="20" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        viewbox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M5 12h14"></path>
                                        <path d="M12 5v14"></path>
                                    </svg>
                                    <svg class="icon-close hidden" fill="none" height="20" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        viewbox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M18 6 6 18"></path>
                                        <path d="m6 6 12 12"></path>
                                    </svg>
                                </button>
                            </div>
                            <div
                                class="accordion-content grid transition-[grid-template-rows] duration-300 ease-in-out grid-rows-[0fr]">
                                <div class="overflow-hidden">
                                    <p class="text-gray-600 pl-10 pr-4 text-sm leading-relaxed pb-6">
                                        Creamos la base de tu nuevo espacio con decks de madera natural o WPC de bajo
                                        mantenimiento. Estas superficies, además de ser resistentes y estéticas, definen
                                        las
                                        áreas de estar y se integran perfectamente con escalones tipo solárium para
                                        crear
                                        zonas de relax y descanso.
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="border-b border-gray-200 accordion-item" data-image={proyHidroia.src}>
                            <div class="flex justify-between items-center py-5 cursor-pointer accordion-header">
                                <div class="flex items-center gap-4">
                                    <svg class="text-gray-700" fill="none" height="24" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                        viewbox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M2 12h20"></path>
                                        <path d="M20 12v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-8"></path>
                                        <path d="M4 6v6"></path>
                                        <path d="M20 6v6"></path>
                                        <path d="M12 2v10"></path>
                                    </svg>
                                    <h3 class="text-lg font-medium text-gray-900 accordion-title">Hidromasajes y Espejos
                                        de Agua</h3>
                                </div>
                                <button aria-label="Alternar detalle del servicio" class="text-gray-400 hover:text-gray-700">
                                    <svg class="icon-plus block" fill="none" height="20" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        viewbox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M5 12h14"></path>
                                        <path d="M12 5v14"></path>
                                    </svg>
                                    <svg class="icon-close hidden" fill="none" height="20" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        viewbox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M18 6 6 18"></path>
                                        <path d="m6 6 12 12"></path>
                                    </svg>
                                </button>
                            </div>
                            <div
                                class="accordion-content grid transition-[grid-template-rows] duration-300 ease-in-out grid-rows-[0fr]">
                                <div class="overflow-hidden">
                                    <p class="text-gray-600 pl-10 pr-4 text-sm leading-relaxed pb-6">
                                        Añadimos un toque de lujo y serenidad con la instalación de hidromasajes o
                                        espejos
                                        de agua. Estos elementos se convierten en el punto focal del diseño, aportando
                                        un
                                        sonido relajante y una experiencia de spa privado en tu propia casa.
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="border-b border-gray-200 accordion-item" data-image={proyPergola.src}>
                            <div class="flex justify-between items-center py-5 cursor-pointer accordion-header">
                                <div class="flex items-center gap-4">
                                    <svg class="text-gray-700" fill="none" height="24" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                        viewbox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M3 21h18"></path>
                                        <path d="M3 7v14"></path>
                                        <path d="M21 7v14"></path>
                                        <path d="M3 7l9-5 9 5"></path>
                                    </svg>
                                    <h3 class="text-lg font-medium text-gray-900 accordion-title">Pérgolas y
                                        Cerramientos</h3>
                                </div>
                                <button aria-label="Alternar detalle del servicio" class="text-gray-400 hover:text-gray-700">
                                    <svg class="icon-plus block" fill="none" height="20" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        viewbox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M5 12h14"></path>
                                        <path d="M12 5v14"></path>
                                    </svg>
                                    <svg class="icon-close hidden" fill="none" height="20" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        viewbox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M18 6 6 18"></path>
                                        <path d="m6 6 12 12"></path>
                                    </svg>
                                </button>
                            </div>
                            <div
                                class="accordion-content grid transition-[grid-template-rows] duration-300 ease-in-out grid-rows-[0fr]">
                                <div class="overflow-hidden">
                                    <p class="text-gray-600 pl-10 pr-4 text-sm leading-relaxed pb-6">
                                        Extendemos la funcionalidad de tu terraza para que puedas disfrutarla todo el
                                        año.
                                        Diseñamos e instalamos pérgolas de diseño para generar sombra y confort, junto a
                                        cerramientos vidriados panorámicos que protegen del viento y la lluvia sin
                                        sacrificar las vistas.
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="border-b border-gray-200 accordion-item" data-image={proyPanel.src}>
                            <div class="flex justify-between items-center py-5 cursor-pointer accordion-header">
                                <div class="flex items-center gap-4">
                                    <svg class="text-gray-700" fill="none" height="24" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                        viewbox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg">
                                        <circle cx="12" cy="12" r="4"></circle>
                                        <path d="M12 2v2"></path>
                                        <path d="M12 20v2"></path>
                                        <path d="m4.93 4.93 1.41 1.41"></path>
                                        <path d="m17.66 17.66 1.41 1.41"></path>
                                        <path d="M2 12h2"></path>
                                        <path d="M20 12h2"></path>
                                        <path d="m6.34 17.66-1.41 1.41"></path>
                                        <path d="m19.07 4.93-1.41 1.41"></path>
                                    </svg>
                                    <h3 class="text-lg font-medium text-gray-900 accordion-title">Energía Solar y
                                        Sostenibilidad</h3>
                                </div>
                                <button aria-label="Alternar detalle del servicio" class="text-gray-400 hover:text-gray-700">
                                    <svg class="icon-plus block" fill="none" height="20" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        viewbox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M5 12h14"></path>
                                        <path d="M12 5v14"></path>
                                    </svg>
                                    <svg class="icon-close hidden" fill="none" height="20" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        viewbox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M18 6 6 18"></path>
                                        <path d="m6 6 12 12"></path>
                                    </svg>
                                </button>
                            </div>
                            <div
                                class="accordion-content grid transition-[grid-template-rows] duration-300 ease-in-out grid-rows-[0fr]">
                                <div class="overflow-hidden">
                                    <p class="text-gray-600 pl-10 pr-4 text-sm leading-relaxed pb-6">
                                        Transformamos tu terraza en una fuente de energía limpia y renovable. Realizamos
                                        la
                                        instalación de paneles solares que te permiten reducir tu consumo eléctrico y
                                        contribuir al medio ambiente. Una solución inteligente que añade valor y
                                        eficiencia
                                        energética a tu propiedad.
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="border-b border-gray-200 accordion-item" data-image={proyTecno.src}>
                            <div class="flex justify-between items-center py-5 cursor-pointer accordion-header">
                                <div class="flex items-center gap-4">
                                    <svg class="text-gray-700" fill="none" height="24" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                        viewbox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg">
                                        <rect height="14" rx="2" width="20" x="2" y="3"></rect>
                                        <line x1="8" x2="16" y1="21" y2="21"></line>
                                        <line x1="12" x2="12" y1="17" y2="21"></line>
                                    </svg>
                                    <h3 class="text-lg font-medium text-gray-900 accordion-title">Tecnología y
                                        Entretenimiento</h3>
                                </div>
                                <button class="text-gray-400 hover:text-gray-700">
                                    <svg class="icon-plus block" fill="none" height="20" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        viewbox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M5 12h14"></path>
                                        <path d="M12 5v14"></path>
                                    </svg>
                                    <svg class="icon-close hidden" fill="none" height="20" stroke="currentColor"
                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        viewbox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M18 6 6 18"></path>
                                        <path d="m6 6 12 12"></path>
                                    </svg>
                                </button>
                            </div>
                            <div
                                class="accordion-content grid transition-[grid-template-rows] duration-300 ease-in-out grid-rows-[0fr]">
                                <div class="overflow-hidden">
                                    <p class="text-gray-600 pl-10 pr-4 text-sm leading-relaxed pb-6">
                                        Equipamos tu nuevo espacio con la mejor tecnología para el ocio y el confort.
                                        Integramos sistemas de sonido con parlantes Bluetooth, proyectores con pantallas
                                        retráctiles y conexiones para TV o consolas. Controlá el ambiente y la diversión
                                        desde la comodidad de tu celular.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <script>
                            document.addEventListener('DOMContentLoaded', () => {
                                const accordionItems = document.querySelectorAll('.accordion-item');
                                const serviceImage = document.getElementById('service-image') as HTMLImageElement;

                                accordionItems.forEach(item => {
                                    const header = item.querySelector('.accordion-header');
                                    header.addEventListener('click', () => {
                                        // Close all others
                                        accordionItems.forEach(otherItem => {
                                            if (otherItem !== item && otherItem.classList.contains('is-active')) {
                                                otherItem.classList.remove('is-active');
                                                const otherContent = otherItem.querySelector('.accordion-content');
                                                const otherTitle = otherItem.querySelector('.accordion-title');
                                                const otherPlus = otherItem.querySelector('.icon-plus');
                                                const otherClose = otherItem.querySelector('.icon-close');

                                                otherContent.classList.remove('grid-rows-[1fr]');
                                                otherContent.classList.add('grid-rows-[0fr]');
                                                otherTitle.classList.remove('font-semibold');
                                                otherTitle.classList.add('font-medium');
                                                otherPlus.classList.remove('hidden');
                                                otherPlus.classList.add('block');
                                                otherClose.classList.remove('block');
                                                otherClose.classList.add('hidden');
                                            }
                                        });

                                        // Toggle current
                                        item.classList.toggle('is-active');
                                        const content = item.querySelector('.accordion-content');
                                        const title = item.querySelector('.accordion-title');
                                        const plus = item.querySelector('.icon-plus');
                                        const close = item.querySelector('.icon-close');

                                        if (item.classList.contains('is-active')) {
                                            // Update Image with transition
                                            const newImageSrc = item.getAttribute('data-image');
                                            if (newImageSrc && serviceImage) {
                                                serviceImage.classList.remove('opacity-100');
                                                serviceImage.classList.add('opacity-0');

                                                setTimeout(() => {
                                                    serviceImage.removeAttribute('srcset');
                                                    serviceImage.removeAttribute('sizes');
                                                    serviceImage.src = newImageSrc;
                                                    serviceImage.onload = () => {
                                                        serviceImage.classList.remove('opacity-0');
                                                        serviceImage.classList.add('opacity-100');
                                                    };
                                                }, 300);
                                            }

                                            content.classList.remove('grid-rows-[0fr]');
                                            content.classList.add('grid-rows-[1fr]');
                                            title.classList.remove('font-medium');
                                            title.classList.add('font-semibold');
                                            plus.classList.remove('block');
                                            plus.classList.add('hidden');
                                            close.classList.remove('hidden');
                                            close.classList.add('block');
                                        } else {
                                            content.classList.remove('grid-rows-[1fr]');
                                            content.classList.add('grid-rows-[0fr]');
                                            title.classList.remove('font-semibold');
                                            title.classList.add('font-medium');
                                            plus.classList.remove('hidden');
                                            plus.classList.add('block');
                                            close.classList.remove('block');
                                            close.classList.add('hidden');
                                        }
                                    });
                                });
                            });
                        </script>
                    </div>
                </div>
            </div>
        </section>
        <!-- BEGIN: StackedCardsSection (Project Showcase & Guarantee) -->