<section
    id="contacto"
    class="py-24 lg:px-16 bg-[#13141A] text-white px-6"
    data-purpose="contact-section"
>
    <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-16">
        <!-- Left Contact Info -->
        <div class="w-full lg:w-1/2">
            <span
                class="inline-block bg-gray-100 text-gray-900 text-xs font-medium px-3 py-1 rounded-full mb-6"
            >
                Contacto
            </span>
            <h2
                class="lg:text-5xl font-semibold tracking-tight mb-6 leading-tight text-3xl"
            >
                Hablemos de tu Proyecto.
            </h2>
            <p class="text-gray-400 mb-12 text-sm leading-relaxed max-w-md">
                Estamos listos para evaluar tu terraza y proponerte la mejor
                solución. Completá el formulario o contactanos para coordinar
                una visita técnica sin cargo.
            </p>
            <div class="space-y-6 text-sm">
                <!-- <div class="flex justify-between items-center border-b border-gray-800 pb-4">
                            <span class="text-gray-400">Email</span>
                            <span class="">info@terrazasrooftop.com.ar</span>
                        </div> -->
                <div
                    class="flex justify-between items-center border-b border-gray-800 pb-4"
                >
                    <span class="text-gray-400">Teléfono</span>
                    <span class="">+54 9 11 5951-6786</span>
                </div>
                <div class="pt-4">
                    <span class="block text-gray-400 mb-3">Seguinos</span>
                    <div class="flex gap-4">
                        <!-- Social Icons -->
                        <a
                            aria-label="Instagram"
                            class="text-gray-400 hover:text-white transition-colors"
                            href="https://www.instagram.com/terrazasrooftop"
                        >
                            <svg
                                fill="none"
                                height="20"
                                stroke="currentColor"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                viewbox="0 0 24 24"
                                width="20"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <rect
                                    height="20"
                                    rx="5"
                                    ry="5"
                                    width="20"
                                    x="2"
                                    y="2"></rect>
                                <path
                                    d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                                ></path>
                                <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"
                                ></line>
                            </svg>
                        </a>
                        <a
                            aria-label="TikTok"
                            class="hidden text-gray-400 hover:text-white transition-colors"
                            href="#"
                        >
                            <svg
                                fill="none"
                                height="20"
                                stroke="currentColor"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                viewbox="0 0 24 24"
                                width="20"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"
                                ></path>
                            </svg>
                        </a>
                        <a
                            aria-label="X (Twitter)"
                            class="hidden text-gray-400 hover:text-white transition-colors"
                            href="#"
                        >
                            <svg
                                fill="none"
                                height="20"
                                stroke="currentColor"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                viewbox="0 0 24 24"
                                width="20"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path d="M4 4l11.733 16h4.267l-11.733 -16z"
                                ></path>
                                <path
                                    d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"
                                ></path>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <!-- Right Contact Form -->
        <div class="w-full lg:w-1/2">
            <div class="bg-white rounded-2xl p-8 lg:p-10 text-gray-900">
                <form id="whatsapp-form" class="space-y-5">
                    <div>
                        <label
                            class="block text-xs font-medium text-gray-700 mb-1"
                            for="nombre">Nombre*</label
                        >
                        <input
                            required
                            class="w-full bg-gray-50 border border-gray-200 rounded-md py-3 px-4 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400"
                            id="nombre"
                            name="nombre"
                            placeholder="Juan Pérez"
                            type="text"
                        />
                    </div>
                    <div>
                        <label
                            class="block text-xs font-medium text-gray-700 mb-1"
                            for="email">Email*</label
                        >
                        <input
                            required
                            class="w-full bg-gray-50 border border-gray-200 rounded-md py-3 px-4 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400"
                            id="email"
                            name="email"
                            placeholder="tu@email.com"
                            type="email"
                        />
                    </div>
                    <div>
                        <label
                            class="block text-xs font-medium text-gray-700 mb-1"
                            for="telefono">Número Celular*</label
                        >
                        <input
                            required
                            class="w-full bg-gray-50 border border-gray-200 rounded-md py-3 px-4 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400"
                            id="telefono"
                            name="telefono"
                            placeholder="+54 9 11 5951-6786"
                            type="tel"
                        />
                    </div>
                    <div>
                        <label
                            class="block text-xs font-medium text-gray-700 mb-1"
                            for="mensaje">Mensaje*</label
                        >
                        <textarea
                            required
                            class="w-full bg-gray-50 border border-gray-200 rounded-md py-3 px-4 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 resize-none"
                            id="mensaje"
                            name="mensaje"
                            placeholder="Hola, necesito una visita técnica para revisar la viabilidad de construir en mi terraza."
                            rows="4"></textarea>
                    </div>
                    <button
                        class="w-full bg-[#444444] hover:bg-gray-800 text-white font-medium py-3 rounded-md text-sm transition-colors mt-2"
                        type="submit"
                    >
                        Enviar Mensaje
                    </button>
                </form>
                <script>
                    document
                        .getElementById("whatsapp-form")
                        .addEventListener("submit", function (e) {
                            e.preventDefault();
                            const nombre =
                                document.getElementById("nombre").value;
                            const email =
                                document.getElementById("email").value;
                            const telefono =
                                document.getElementById("telefono").value ||
                                "No proporcionado";
                            const mensaje =
                                document.getElementById("mensaje").value;

                            const text = `Hola! Me contacto desde la web de Terrazas Rooftop.\n\n*Nombre:* ${nombre}\n*Email:* ${email}\n*Teléfono:* ${telefono}\n*Mensaje:* ${mensaje}`;
                            const encodedText = encodeURIComponent(text);
                            const whatsappUrl = `https://wa.me/5491159516786?text=${encodedText}`;

                            window.open(whatsappUrl, "_blank");
                        });
                </script>
            </div>
        </div>
    </div>
</section>
<!-- END: ContactSection -->
